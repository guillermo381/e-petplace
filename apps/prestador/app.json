{
  "expo": {
    "name": "prestador",
    "slug": "prestador",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "prestador",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.epetplace.prestador"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "La app usa la cámara para registrar la evidencia de cada atención (fotos del servicio).",
          "photosPermission": "La app accede a tus fotos solo cuando elegís una imagen como evidencia de una atención."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "La app usa tu ubicación durante el paseo para registrar el recorrido que ve la familia."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "83a4d295-764e-4067-add2-e91512c06649"
      }
    },
    "owner": "guillo381",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/83a4d295-764e-4067-add2-e91512c06649"
    }
  }
}
